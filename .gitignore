# Ignore everything by default
/*

# But do not ignore the following folders
!/frontend/
!/backend/
!/.gitignore

# Ignore dependencies and build artifacts within those folders
backend/package-lock.json
backend/uploads/
**/node_modules/
**/dist/
**/.expo/
**/web-build/
**/build/
**/.next/
**/out/

# Ignore local environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
